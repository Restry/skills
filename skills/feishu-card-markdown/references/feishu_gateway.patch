+def _derive_card_title(content: str, max_chars: int = 28) -> str:
+    """Pick the first non-empty content line and clean it for use as a card header.
+
+    Strategy: skip blank lines / fence lines / table delimiter lines, then strip
+    common markdown noise (`#` headers, list bullets, bold/italic/code marks,
+    inline links). Falls back to empty string when nothing usable is found.
+    """
+    if not content:
+        return ""
+    for raw_line in content.splitlines():
+        line = raw_line.strip()
+        if not line:
+            continue
+        if line.startswith("```") or line.startswith("---") or line.startswith("==="):
+            continue
+        # Skip table separator lines like "| --- | --- |"
+        if re.match(r"^\|?\s*:?-{2,}", line):
+            continue
+        # Strip leading markdown markers
+        line = re.sub(r"^#{1,6}\s+", "", line)
+        line = re.sub(r"^[-*+]\s+", "", line)
+        line = re.sub(r"^\d+\.\s+", "", line)
+        line = re.sub(r"^>\s+", "", line)
+        # Strip inline markdown
+        line = re.sub(r"\[([^\]]+)\]\([^)]*\)", r"\1", line)  # links → text
+        line = re.sub(r"`([^`]+)`", r"\1", line)               # code spans
+        line = re.sub(r"\*\*([^*]+)\*\*", r"\1", line)         # bold
+        line = re.sub(r"\*([^*]+)\*", r"\1", line)             # italic
+        line = re.sub(r"~~([^~]+)~~", r"\1", line)             # strike
+        line = re.sub(r"<font[^>]*>", "", line)                 # html font open
+        line = line.replace("</font>", "")
+        line = line.strip()
+        if not line:
+            continue
+        if len(line) > max_chars:
