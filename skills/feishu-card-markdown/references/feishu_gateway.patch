+def _parse_actionable_card(content: str) -> Optional[Dict[str, Any]]:
+    """Detect whether content should render as an interactive card.
+
+    Returns a dict with type ('multi_choice'), question_text, and options when
+    applicable; None when content is plain text. Strategy:
+
+    1. Strip markdown emphasis noise.
+    2. Try **multi_choice**: lines starting with A/B/C/D/E or 1-5 followed by
+       a punctuator (.:、)）. Need >=2 distinct labels.
+
+    Yes/No auto-cards have been intentionally removed — they fire too often on
+    rhetorical or informational trailing questions. Use the `clarify` tool when
+    you really need a 2-button binary confirmation.
+    """
+    if not content:
+        return None
+    text = content.rstrip()
+    # Drop trailing fenced code blocks so question detection looks at
+    # conversational tail, not example code.
+    text = re.sub(r"\n```[\s\S]*?```\s*$", "", text).rstrip()
+    if not text:
+        return None
+    clean = _strip_md_noise(text)
+
+    # ---- Rule 1: explicit A/B/C or 1/2/3 list ----
+    option_re = re.compile(
+        r"(?:^|\n)\s*(?:[-+*]\s*)?([A-Ea-e1-5])\s*[.:：、)）]\s*([^\n]+)"
+    )
+    options_map: Dict[str, str] = {}
+    options_order: List[str] = []
+    for m in option_re.finditer(clean):
+        label = m.group(1).upper()
+        if label not in options_map:
+            options_map[label] = m.group(2).strip()
+            options_order.append(label)
+    if len(options_map) >= 2:
+        first_text = options_map[options_order[0]]
+        before = clean.split(first_text, 1)[0]
+        q_match = re.search(r"([^。！？\n]*?[：:？?])(?:\s*\n)?\s*$", before)
+        q_text = q_match.group(1).strip() if q_match else "请选择："
+        return {
+            "type": "multi_choice",
+            "question_text": q_text,
+            "options": [
+                {"label": lbl, "text": options_map[lbl], "value": lbl}
+                for lbl in options_order
+            ],
+        }
+
+    return None
+
